rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'sash5385@gmail.com';
    }

    // Інструктори
    match /instructors/{docId} {
      allow read: if isAdmin()
               || resource.data.status == 'approved'
               || (request.auth != null && resource.data.userId == request.auth.uid)
               || (request.auth != null && resource.data.email == request.auth.token.email);
      // Анкету може надіслати будь-хто (auth необов'язковий), статус тільки pending
      allow create: if request.resource.data.status == 'pending';
      // Інструктор може редагувати власний профіль, але не може змінювати статус
      allow update: if isAdmin()
                 || (request.auth != null
                     && resource.data.userId == request.auth.uid
                     && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']))
                 // Дозволяє прив'язати userId якщо він порожній і email співпадає
                 || (request.auth != null
                     && resource.data.userId == null
                     && resource.data.email == request.auth.token.email
                     && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId']));
      allow delete: if isAdmin();
    }

    // Профілі учнів
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Бронювання
    match /bookings/{bookingId} {
      // Читання відкрите — потрібно для перевірки вільних слотів
      allow read: if true;

      // Клієнт бронює (clientId == своя uid, статус pending)
      allow create: if request.auth != null
                    && request.resource.data.clientId == request.auth.uid
                    && request.resource.data.status == 'pending';

      // Клієнт скасовує свій запис (тільки status → cancelled)
      allow update: if request.auth != null
                    && resource.data.clientId == request.auth.uid
                    && request.resource.data.status == 'cancelled'
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      // Інструктор підтверджує / скасовує (якщо є instructorUserId)
      allow update: if request.auth != null
                    && resource.data.instructorUserId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      // Адмін — повний доступ
      allow update, delete: if isAdmin();
    }
  }
}
